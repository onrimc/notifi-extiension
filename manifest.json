{
  "manifest_version": 3,
  "name": "Notifi",
  "version": "1.0.0",
  "description": "A simple and persistent note-taking extension inside the browser.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_title": "Open Note"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}